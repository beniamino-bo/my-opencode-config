{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "instructions": ["user-config.json", "rules.md"],
  "skills": {
    "paths": [".opencode/skills"]
  },
  "permission": {
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "rmdir *": "ask",
      "rm -rf *": "ask",
      "rm -r *": "ask",
      "git *": "ask",
      "ssh *": "ask"
    },
    "external_directory": "deny"
  }  
}


